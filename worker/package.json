{
  "name": "sh-worker",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "check": "npm run check:syntax && npm run check:bundle",
    "check:syntax": "node ../scripts/check-js-syntax.mjs worker/src worker/tests",
    "check:bundle": "wrangler deploy --dry-run --outdir=dist-dry-run",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "wrangler": "^4.104.0"
  }
}
