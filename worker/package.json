{
  "name": "sh-worker",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/select-cloudflare-build-config.mjs",
    "dev": "wrangler dev --test-scheduled",
    "deploy": "node scripts/deploy-connected-worker.mjs",
    "deploy:buddies": "wrangler deploy --config wrangler.jsonc",
    "deploy:ingest": "wrangler deploy --config wrangler.ingest.jsonc",
    "deploy:comments": "wrangler deploy --config wrangler.comments.jsonc",
    "deploy:minute-read-model": "wrangler deploy --config wrangler.read-model.jsonc",
    "deploy:track-metadata": "wrangler deploy --config wrangler.track-metadata.jsonc",
    "deploy:pages-read-model": "wrangler deploy --config wrangler.pages-read-model.jsonc",
    "deploy:monitor-maintenance": "wrangler deploy --config wrangler.monitor-maintenance.jsonc",
    "deploy:other": "wrangler deploy --config wrangler.other.jsonc",
    "deploy:buddy-playback": "wrangler deploy --config wrangler.buddy-playback.jsonc",
    "deploy:minute-maintenance": "wrangler deploy --config wrangler.minute.jsonc",
    "deploy:minute-derive": "wrangler deploy --config wrangler.minute-derive.jsonc",
    "deploy:minute-enrichment": "wrangler deploy --config wrangler.minute-enrichment.jsonc",
    "deploy:minute-rebuild": "wrangler deploy --config wrangler.minute-rebuild.jsonc",
    "deploy:minute-ingest": "wrangler deploy --config wrangler.minute-ingest.jsonc",
    "deploy:minute": "npm run deploy:minute-derive && npm run deploy:minute-enrichment && npm run deploy:minute-rebuild && npm run deploy:minute-maintenance && npm run deploy:minute-ingest && npm run deploy:minute-read-model && npm run deploy:track-metadata",
    "deploy:split-other": "npm run deploy:pages-read-model && npm run deploy:monitor-maintenance && npm run deploy:other && npm run deploy:buddy-playback",
    "tail": "wrangler tail",
    "check": "npm run check:syntax && npm run check:bundle",
    "check:syntax": "node ../scripts/check-js-syntax.mjs worker/src worker/tests worker/scripts",
    "check:bundle": "wrangler deploy --dry-run --outdir=dist-dry-run",
    "check:ingest-bundle": "wrangler deploy --config wrangler.ingest.jsonc --dry-run --outdir=dist-ingest-dry-run",
    "check:comments-bundle": "wrangler deploy --config wrangler.comments.jsonc --dry-run --outdir=dist-comments-dry-run",
    "check:minute-read-model-bundle": "wrangler deploy --config wrangler.read-model.jsonc --dry-run --outdir=dist-minute-read-model-dry-run",
    "check:track-metadata-bundle": "wrangler deploy --config wrangler.track-metadata.jsonc --dry-run --outdir=dist-track-metadata-dry-run",
    "check:pages-read-model-bundle": "wrangler deploy --config wrangler.pages-read-model.jsonc --dry-run --outdir=dist-pages-read-model-dry-run",
    "check:monitor-maintenance-bundle": "wrangler deploy --config wrangler.monitor-maintenance.jsonc --dry-run --outdir=dist-monitor-maintenance-dry-run",
    "check:other-bundle": "wrangler deploy --config wrangler.other.jsonc --dry-run --outdir=dist-other-dry-run",
    "check:buddy-playback-bundle": "wrangler deploy --config wrangler.buddy-playback.jsonc --dry-run --outdir=dist-buddy-playback-dry-run",
    "check:minute-maintenance-bundle": "wrangler deploy --config wrangler.minute.jsonc --dry-run --outdir=dist-minute-maintenance-dry-run",
    "check:minute-derive-bundle": "wrangler deploy --config wrangler.minute-derive.jsonc --dry-run --outdir=dist-minute-derive-dry-run",
    "check:minute-enrichment-bundle": "wrangler deploy --config wrangler.minute-enrichment.jsonc --dry-run --outdir=dist-minute-enrichment-dry-run",
    "check:minute-rebuild-bundle": "wrangler deploy --config wrangler.minute-rebuild.jsonc --dry-run --outdir=dist-minute-rebuild-dry-run",
    "check:minute-ingest-bundle": "wrangler deploy --config wrangler.minute-ingest.jsonc --dry-run --outdir=dist-minute-ingest-dry-run",
    "check:minute-bundle": "npm run check:minute-maintenance-bundle && npm run check:minute-derive-bundle && npm run check:minute-enrichment-bundle && npm run check:minute-rebuild-bundle && npm run check:minute-ingest-bundle && npm run check:minute-read-model-bundle && npm run check:track-metadata-bundle",
    "check:split-other-bundle": "npm run check:pages-read-model-bundle && npm run check:monitor-maintenance-bundle && npm run check:other-bundle && npm run check:buddy-playback-bundle",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "sh-shared": "file:../packages/sh-shared"
  },
  "devDependencies": {
    "wrangler": "^4.104.0"
  }
}
