{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sh-minute-ingest",
  "main": "src/minute-production-entry.js",
  "compatibility_date": "2026-06-24",
  "workers_dev": false,
  "preview_urls": false,
  "logpush": true,
  "observability": { "enabled": true },
  "vars": {
    "REQUEST_TIMEOUT_MS": 8000,
    "METADATA_LIMIT": 1,
    "ISRC_METADATA_LIMIT": 1
  },
  "d1_databases": [
    { "binding": "BUDDIES_DB", "database_name": "stationhead-buddies", "database_id": "f361aae0-05f0-42bc-8784-77100e80133d" },
    { "binding": "MINUTE_DB", "database_name": "stationhead-minute", "database_id": "43c12c1e-886d-4496-9c37-61bc8a15bbd7" }
  ],
  "queues": {
    "consumers": [
      {
        "queue": "stationhead-buddies-facts",
        "max_batch_size": 1,
        "max_batch_timeout": 1,
        "max_retries": 8,
        "dead_letter_queue": "stationhead-buddies-facts-dlq"
      }
    ],
    "producers": [
      { "binding": "MINUTE_DERIVE_QUEUE", "queue": "stationhead-minute-derive" }
    ]
  }
}
