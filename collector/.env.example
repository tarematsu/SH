# Cloudflare Pages/Worker 側の受信API
INGEST_URL=https://YOUR-PAGES-DOMAIN.pages.dev/api/ingest
INGEST_SECRET=CHANGE_ME

# Local collector mode: auto / active / standby
COLLECTOR_MODE=auto
COORDINATION_URL=https://stationhead-monitor-collector.tarematsu.workers.dev/coordination/lease
FAILOVER_CHECK_INTERVAL_MS=30000
FAILOVER_GRACE_MS=180000
FAILOVER_SHUTDOWN_TIMEOUT_MS=15000

# Stationhead
CHANNEL_ALIAS=buddies
POLL_INTERVAL_MS=60000
CHAT_LIMIT=50
ENABLE_WEBSOCKET=true

# ローカル収集の保存済み曲メタデータ照会キャッシュ
TRACK_LOOKUP_CACHE_MS=300000
TRACK_LOOKUP_CACHE_MAX=16

# 任意: ログレベル debug / info / warn / error
LOG_LEVEL=info

# Usually blank. Set only if Stationhead still returns 401.
STATIONHEAD_COOKIE=

# Stationhead guest API and local weekly leaderboard authentication.
# collector.mjs can refresh these automatically and writes .sh-session.json.
STATIONHEAD_AUTH_TOKEN=
STATIONHEAD_DEVICE_UID=
STATIONHEAD_APP_VERSION=1.0.0

# Optional host/solo monitoring overrides
HOST_MONITOR_ENABLED=true
HOST_PROFILE_HANDLE=sakuramankai
HOST_PROFILE_ACCOUNT_ID=3334889
HOST_PROFILE_INTERVAL_MS=3600000
SOLO_BROADCAST_HANDLE=sakurazaka46jp
SOLO_POLL_INTERVAL_MS=60000
SOLO_CONFIRM_POLLS=2
SOLO_END_CONFIRM_POLLS=3
SOLO_CHAT_LIMIT=100
SOLO_PROFILE_INTERVAL_MS=3600000
SOLO_ENABLE_WEBSOCKET=true

# Optional local weekly leaderboard fallback
WEEKLY_LEADERBOARD_ENABLED=true
WEEKLY_LEADERBOARD_CHECK_MINUTES=15
WEEKLY_LEADERBOARD_START_HOUR_JST=18
WEEKLY_LEADERBOARD_END_HOUR_JST=2
WEEKLY_LEADERBOARD_MIN_ACCOUNTS=20
