# Cloudflare Pages/Worker 側の受信API
INGEST_URL=https://YOUR-PAGES-DOMAIN.pages.dev/api/ingest
INGEST_SECRET=CHANGE_ME

# Stationhead
CHANNEL_ALIAS=buddies
POLL_INTERVAL_MS=60000
CHAT_LIMIT=50
ENABLE_WEBSOCKET=true

# 任意: ログレベル debug / info / warn / error
LOG_LEVEL=info

# Usually blank. Set only if Stationhead still returns 401.
STATIONHEAD_COOKIE=

# Required for Stationhead API
STATIONHEAD_AUTH_TOKEN=
STATIONHEAD_DEVICE_UID=
STATIONHEAD_APP_VERSION=1.0.0
