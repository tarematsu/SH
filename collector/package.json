{
  "name": "stationhead-local-collector",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node run-failover.mjs",
    "start:auto": "node run-failover.mjs",
    "start:active": "set COLLECTOR_MODE=active&& node run-failover.mjs",
    "start:standby": "set COLLECTOR_MODE=standby&& node run-failover.mjs",
    "start:direct": "node --import ./fetch-cache.mjs collector.mjs",
    "once": "node --import ./fetch-cache.mjs collector.mjs --once",
    "check": "node --check collector.mjs && node --check host-monitor.mjs && node --check run-failover.mjs && node --check weekly-leaderboard.mjs && node --check fetch-cache.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ws": "^8.18.0",
    "fetch-cookie": "^3.1.0",
    "tough-cookie": "^5.1.2",
    "playwright-core": "^1.53.0"
  }
}
