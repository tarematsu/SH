{
  "name": "sh-site",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public",
    "build": "npm test && npm run db:guard && npm run db:migrate && npm run db:verify",
    "db:guard": "node scripts/check-tokenless-d1-coverage.mjs",
    "db:migrate": "node scripts/apply-d1-migrations.mjs",
    "db:verify": "node scripts/verify-d1-schema.mjs",
    "check": "node ../scripts/check-js-syntax.mjs site/functions site/public site/scripts site/tests",
    "test": "npm run test:integration && npm run test:d1",
    "test:integration": "node --test tests/*.test.js",
    "test:d1": "node scripts/test-local-d1.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  }
}
